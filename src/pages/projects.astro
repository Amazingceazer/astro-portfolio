---
// Projects Page
// Project grid with cards, optional filters, and prominent newsletter CTA
import Layout from '../layouts/Layout.astro';
import NewsletterForm from '../components/NewsletterForm.astro';
import CTAButton from '../components/CTAButton.astro';
---

<Layout title="Projects | Avalumun Sekulla Nyior" description="View my portfolio of SEO and AEO optimization projects" currentPage="/projects">
  <!-- Hero Section -->
  <section class="container mx-auto px-6 py-24 md:py-32">
    <div class="max-w-4xl mx-auto text-center">
      <h1 class="font-heading font-bold text-5xl md:text-6xl mb-6 text-text-primary">
        Portfolio & Case Studies
      </h1>
      <p class="font-body text-xl md:text-2xl text-text-secondary leading-relaxed">
        Real results for B2B SaaS and E-commerce clients. Proven strategies that drive traffic, reduce CAC, and boost revenue.
      </p>
    </div>
  </section>

  <!-- Newsletter CTA - Prominent Placement -->
  <section class="bg-violent-red py-16 mb-24">
    <div class="container mx-auto px-6">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="font-heading font-bold text-3xl md:text-4xl mb-4 text-white">
          Get Your Own Case Study
        </h2>
        <p class="font-body text-lg text-white mb-8 opacity-90">
          Subscribe to receive the latest case studies and strategies showing how we're transforming SEO for SaaS companies.
        </p>
        <div class="max-w-md mx-auto">
          <form
            id="projects-newsletter-form"
            class="space-y-4"
          >
            <input
              type="email"
              id="projects-newsletter-email"
              name="email"
              placeholder="Enter your email"
              required
              class="w-full px-6 py-4 rounded-lg font-body text-lg focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-violent-red transition-all text-black"
            />
            <div id="projects-newsletter-message" class="hidden text-sm font-body text-white"></div>
            <button
              type="submit"
              class="w-full bg-white text-violent-red font-heading font-bold text-lg px-8 py-4 rounded-lg transition-all duration-300 hover:bg-gray-100 hover:scale-105 focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-violent-red cursor-pointer"
            >
              Subscribe
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- Projects Grid -->
  <section class="container mx-auto px-6 pb-24">
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-12 max-w-7xl mx-auto">
      <!-- Case Study 1: Fintech -->
      <article class="border-2 border-black rounded-lg overflow-hidden hover:shadow-lg transition-shadow">
        <div class="bg-gradient-to-br from-violent-red to-red-600 h-48 flex items-center justify-center text-white text-6xl font-bold">
          📈
        </div>
        <div class="p-6">
          <h3 class="font-heading font-bold text-2xl mb-3 text-text-primary">
            B2B SaaS - Fintech Platform
          </h3>
          <div class="grid grid-cols-3 gap-2 mb-4 text-center">
            <div class="bg-gray-100 p-3 rounded">
              <span class="font-bold text-violent-red text-lg">+240%</span>
              <p class="text-xs text-text-secondary">Organic Growth</p>
            </div>
            <div class="bg-gray-100 p-3 rounded">
              <span class="font-bold text-violent-red text-lg">-45%</span>
              <p class="text-xs text-text-secondary">CAC</p>
            </div>
            <div class="bg-gray-100 p-3 rounded">
              <span class="font-bold text-violent-red text-lg">+180%</span>
              <p class="text-xs text-text-secondary">Signups</p>
            </div>
          </div>
          <p class="font-body text-text-secondary leading-relaxed mb-4 text-sm">
            Helped a fintech startup rank for high-intent keywords targeting financial decision-makers. Increased trial signups by 180% in 6 months through comprehensive technical SEO and content strategy.
          </p>
          <div class="flex gap-2 mb-4">
            <span class="inline-block px-2 py-1 bg-gray-200 text-xs font-bold text-violent-red rounded">Technical SEO</span>
            <span class="inline-block px-2 py-1 bg-gray-200 text-xs font-bold text-violent-red rounded">Content</span>
          </div>
          <a
            href="#"
            class="inline-block font-body font-bold italic text-violent-red hover:text-violent-red-dark transition-colors"
          >
            View Details →
          </a>
        </div>
      </article>

      <!-- Case Study 2: E-commerce -->
      <article class="border-2 border-black rounded-lg overflow-hidden hover:shadow-lg transition-shadow">
        <div class="bg-gradient-to-br from-violent-red to-red-600 h-48 flex items-center justify-center text-white text-6xl font-bold">
          🛒
        </div>
        <div class="p-6">
          <h3 class="font-heading font-bold text-2xl mb-3 text-text-primary">
            E-commerce - Fashion Brand
          </h3>
          <div class="grid grid-cols-3 gap-2 mb-4 text-center">
            <div class="bg-gray-100 p-3 rounded">
              <span class="font-bold text-violent-red text-lg">+320%</span>
              <p class="text-xs text-text-secondary">Traffic</p>
            </div>
            <div class="bg-gray-100 p-3 rounded">
              <span class="font-bold text-violent-red text-lg">+155%</span>
              <p class="text-xs text-text-secondary">Sales</p>
            </div>
            <div class="bg-gray-100 p-3 rounded">
              <span class="font-bold text-violent-red text-lg">-35%</span>
              <p class="text-xs text-text-secondary">CAC</p>
            </div>
          </div>
          <p class="font-body text-text-secondary leading-relaxed mb-4 text-sm">
            Enhanced product page visibility with schema markup and improved category structure for international markets. Achieved 320% traffic increase and 155% revenue boost.
          </p>
          <div class="flex gap-2 mb-4">
            <span class="inline-block px-2 py-1 bg-gray-200 text-xs font-bold text-violent-red rounded">E-commerce SEO</span>
            <span class="inline-block px-2 py-1 bg-gray-200 text-xs font-bold text-violent-red rounded">Schema</span>
          </div>
          <a
            href="#"
            class="inline-block font-body font-bold italic text-violent-red hover:text-violent-red-dark transition-colors"
          >
            View Details →
          </a>
        </div>
      </article>

      <!-- Case Study 3: AI Tools -->
      <article class="border-2 border-black rounded-lg overflow-hidden hover:shadow-lg transition-shadow">
        <div class="bg-gradient-to-br from-violent-red to-red-600 h-48 flex items-center justify-center text-white text-6xl font-bold">
          🤖
        </div>
        <div class="p-6">
          <h3 class="font-heading font-bold text-2xl mb-3 text-text-primary">
            SaaS - AI Tools Platform
          </h3>
          <div class="grid grid-cols-3 gap-2 mb-4 text-center">
            <div class="bg-gray-100 p-3 rounded">
              <span class="font-bold text-violent-red text-lg">+180%</span>
              <p class="text-xs text-text-secondary">Visibility</p>
            </div>
            <div class="bg-gray-100 p-3 rounded">
              <span class="font-bold text-violent-red text-lg">+290%</span>
              <p class="text-xs text-text-secondary">Organic</p>
            </div>
            <div class="bg-gray-100 p-3 rounded">
              <span class="font-bold text-violent-red text-lg">-50%</span>
              <p class="text-xs text-text-secondary">CAC</p>
            </div>
          </div>
          <p class="font-body text-text-secondary leading-relaxed mb-4 text-sm">
            Pioneered AI-powered SEO strategy targeting emerging generative search use cases. Dominated category keywords with GEO/LLM focused content clusters and technical optimization.
          </p>
          <div class="flex gap-2 mb-4">
            <span class="inline-block px-2 py-1 bg-gray-200 text-xs font-bold text-violent-red rounded">GEO/LLM</span>
            <span class="inline-block px-2 py-1 bg-gray-200 text-xs font-bold text-violent-red rounded">Content</span>
          </div>
          <a
            href="#"
            class="inline-block font-body font-bold italic text-violent-red hover:text-violent-red-dark transition-colors"
          >
            View Details →
          </a>
        </div>
      </article>
    </div>
  </section>

  <!-- Secondary Newsletter CTA -->
  <section class="container mx-auto px-6 py-24">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="font-heading font-bold text-4xl md:text-5xl mb-6 text-text-primary">
        Ready to Transform Your SEO?
      </h2>
      <p class="font-body text-xl text-text-secondary mb-12 leading-relaxed">
        These results are achievable for your SaaS company too. Subscribe to get a free 30-minute strategy session to discuss your growth potential.
      </p>
      <NewsletterForm />
    </div>
  </section>
</Layout>

<script>
  // Handle projects page newsletter form
  const projectsForm = document.getElementById('projects-newsletter-form') as HTMLFormElement;
  const projectsEmailInput = document.getElementById('projects-newsletter-email') as HTMLInputElement;
  const projectsMessageDiv = document.getElementById('projects-newsletter-message') as HTMLDivElement;

  if (projectsForm) {
    projectsForm.addEventListener('submit', (e) => {
      e.preventDefault();
      
      const email = projectsEmailInput.value.trim();
      const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      
      if (!emailRegex.test(email)) {
        projectsMessageDiv.textContent = 'Please enter a valid email address.';
        projectsMessageDiv.className = 'text-white text-sm font-body';
        projectsMessageDiv.classList.remove('hidden');
        return;
      }

      console.log('Projects newsletter subscription:', { email, timestamp: new Date().toISOString() });
      
      projectsMessageDiv.textContent = 'Thank you for subscribing!';
      projectsMessageDiv.className = 'text-white text-sm font-body font-bold';
      projectsMessageDiv.classList.remove('hidden');
      
      projectsEmailInput.value = '';
      
      setTimeout(() => {
        projectsMessageDiv.classList.add('hidden');
      }, 5000);
    });
  }
</script>
