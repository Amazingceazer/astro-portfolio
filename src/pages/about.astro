---
// About Page
// Profile section, conference speaking, expertise, and newsletter CTA
import Layout from '../layouts/Layout.astro';
import NewsletterForm from '../components/NewsletterForm.astro';
---

<Layout title="About | Avalumun Sekulla Nyior" description="Learn more about Avalumun Sekulla Nyior" currentPage="/about">
  <!-- Profile Section -->
  <section class="container mx-auto px-6 py-24 md:py-32">
    <div class="max-w-4xl mx-auto">
      <h1 class="font-heading font-bold text-5xl md:text-6xl mb-12 text-text-primary">
        About Me
      </h1>
      
      <div class="space-y-8 mb-16">
        <div class="font-body text-lg md:text-xl text-text-secondary leading-loose">
          <p class="mb-6">
            I'm a B2B SaaS SEO specialist with 300+ successful client campaigns. I help SaaS companies scale organic traffic and qualified leads through data-driven strategies that target high-intent buyers.
          </p>
          <p class="mb-6">
            My expertise spans technical SEO, content strategy, GEO/LLM optimization, and link building. I've generated $5M+ in revenue for clients while reducing customer acquisition costs by 50% or more. My approach focuses on transforming SEO into a predictable, profitable acquisition channel.
          </p>
          <p class="font-bold italic text-violent-red text-xl">
            &ldquo;I don't just optimize for traffic—I optimize for profit and pipeline.&rdquo;
          </p>
        </div>
      </div>

      <!-- Profile Image -->
      <div class="mb-16">
        <img
          src="/my_profile3.jpeg"
          alt="Avalumun Sekulla Nyior - B2B SaaS SEO Expert"
          class="w-full max-w-md mx-auto h-auto rounded-lg object-cover shadow-lg border-2 border-black"
        />
      </div>
    </div>
  </section>

  <!-- Conference Speaking Section -->
  <section class="container mx-auto px-6 py-24 md:py-32">
    <div class="max-w-4xl mx-auto">
      <h2 class="font-heading font-bold text-4xl md:text-5xl mb-12 text-text-primary">
        Speaking at SEO Conferences
      </h2>
      
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <!-- Left Caption -->
        <div class="space-y-6">
          <p class="font-body text-lg md:text-xl text-text-secondary leading-loose">
            Sharing insights on B2B SaaS SEO strategies and best practices. Recently spoke at the <span class="font-bold text-violent-red">SEO Conference, Jos Plateau State</span>, discussing how to scale organic traffic for SaaS companies through data-driven strategies.
          </p>
          <p class="font-body text-lg md:text-xl text-text-secondary leading-loose">
            Join me at upcoming conferences to learn how to implement advanced SEO techniques that drive qualified leads for your B2B SaaS business.
          </p>
        </div>

        <!-- Right Image -->
        <div class="relative rounded-xl overflow-hidden shadow-lg border-2 border-black">
          <img
            src="/conference-speaking.jpg"
            alt="Speaking at SEO Conference, Jos Plateau State"
            class="w-full h-auto object-cover"
          />
          <div class="absolute bottom-0 left-0 right-0 bg-black/60 p-4">
            <p class="text-white font-bold text-center">
              SEO Conference • Jos Plateau State
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Core Expertise Section -->
  <section class="bg-white border-y-2 border-black py-24">
    <div class="container mx-auto px-6">
      <h2 class="font-heading font-bold text-4xl md:text-5xl mb-16 text-center text-text-primary">
        Core Expertise
      </h2>
      
      <div class="max-w-4xl mx-auto">
        <div class="grid md:grid-cols-2 gap-12">
          <!-- SEO Specialties -->
          <div>
            <h3 class="font-heading font-bold text-2xl mb-6 text-violent-red">
              🔍 SEO Specialties
            </h3>
            <ul class="space-y-4 font-body text-lg text-text-secondary">
              <li class="flex items-start">
                <span class="text-violent-red mr-3 font-bold">•</span>
                <span>B2B SaaS SEO</span>
              </li>
              <li class="flex items-start">
                <span class="text-violent-red mr-3 font-bold">•</span>
                <span>E-commerce SEO</span>
              </li>
              <li class="flex items-start">
                <span class="text-violent-red mr-3 font-bold">•</span>
                <span>Technical SEO & Site Audits</span>
              </li>
              <li class="flex items-start">
                <span class="text-violent-red mr-3 font-bold">•</span>
                <span>Content Strategy & Clusters</span>
              </li>
            </ul>
          </div>

          <!-- AI SEO & Tools -->
          <div>
            <h3 class="font-heading font-bold text-2xl mb-6 text-violent-red">
              🤖 AI SEO & Tools
            </h3>
            <ul class="space-y-4 font-body text-lg text-text-secondary">
              <li class="flex items-start">
                <span class="text-violent-red mr-3 font-bold">•</span>
                <span>GEO (Generative Engine Optimization)</span>
              </li>
              <li class="flex items-start">
                <span class="text-violent-red mr-3 font-bold">•</span>
                <span>LLM SEO & AI Tools Strategy</span>
              </li>
              <li class="flex items-start">
                <span class="text-violent-red mr-3 font-bold">•</span>
                <span>Ahrefs, SEMrush, GA4, GSC</span>
              </li>
              <li class="flex items-start">
                <span class="text-violent-red mr-3 font-bold">•</span>
                <span>WordPress & Site Speed Optimization</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Newsletter CTA Section -->
  <section class="container mx-auto px-6 py-24">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="font-heading font-bold text-4xl md:text-5xl mb-6 text-text-primary">
        Ready to Transform Your SEO?
      </h2>
      <p class="font-body text-xl text-text-secondary mb-12 leading-relaxed">
        Subscribe for exclusive strategies and case studies. Or book a free 30-minute strategy session to discuss your SEO potential.
      </p>
      <NewsletterForm />
    </div>
  </section>
</Layout>
