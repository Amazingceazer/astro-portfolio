---
// Homepage
// Hero section, featured accomplishments, and newsletter CTA
import Layout from '../layouts/Layout.astro';
import NewsletterForm from '../components/NewsletterForm.astro';
import CTAButton from '../components/CTAButton.astro';
---

<Layout title="Home | Avalumun Sekulla Nyior" description="SEO/AEO optimization expert portfolio" currentPage="/">
  <!-- Hero Section -->
  <section class="container mx-auto px-6 py-24 md:py-32">
    <div class="max-w-4xl mx-auto text-center">
      <h1 class="font-heading font-bold text-5xl md:text-7xl mb-6 text-text-primary">
        B2B SaaS SEO Expert
      </h1>
      <!-- profile avatar in hero -->
      <img src="/profile.png" alt="Avalumun Sekulla Nyior" class="w-24 h-24 rounded-full mx-auto mb-6 object-cover border-2 border-black" />
      <p class="font-body text-2xl md:text-3xl text-violent-red font-bold mb-12 leading-relaxed">
        Scale Organic Traffic & Qualified Leads
      </p>
      <p class="font-body text-lg md:text-xl text-text-secondary max-w-2xl mx-auto leading-loose mb-12">
        Helping B2B SaaS companies transform SEO into their #1 acquisition channel. My data-driven approach targets high-intent buyers, reducing customer acquisition costs while boosting qualified signups.
      </p>
      <div class="flex justify-center gap-4 flex-wrap">
        <CTAButton text="View Case Studies" href="/projects" />
        <CTAButton text="Free Strategy Session" href="/about" />
      </div>
      <div class="mt-12 flex justify-center gap-3 flex-wrap">
        <span class="px-4 py-2 bg-gray-100 rounded-full text-sm font-bold text-text-primary border-2 border-violent-red">📈 SaaS SEO</span>
        <span class="px-4 py-2 bg-gray-100 rounded-full text-sm font-bold text-text-primary border-2 border-violent-red">🔍 Technical SEO</span>
        <span class="px-4 py-2 bg-gray-100 rounded-full text-sm font-bold text-text-primary border-2 border-violent-red">🤖 GEO/LLM SEO</span>
      </div>
    </div>
  </section>

  <!-- Featured Accomplishments Section -->
  <section class="bg-white border-y-2 border-black py-24">
    <div class="container mx-auto px-6">
      <h2 class="font-heading font-bold text-4xl md:text-5xl mb-16 text-center text-text-primary">
        Proven Results
      </h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8 max-w-6xl mx-auto text-center">
        <!-- Achievement 1 -->
        <article class="space-y-4 p-6 border-2 border-violent-red rounded-lg">
          <h3 class="font-heading font-bold text-4xl text-violent-red">
            300+
          </h3>
          <p class="font-body text-lg font-bold text-text-primary">
            Successful Client Campaigns
          </p>
        </article>

        <!-- Achievement 2 -->
        <article class="space-y-4 p-6 border-2 border-violent-red rounded-lg">
          <h3 class="font-heading font-bold text-4xl text-violent-red">
            240%
          </h3>
          <p class="font-body text-lg font-bold text-text-primary">
            Average Organic Growth
          </p>
        </article>

        <!-- Achievement 3 -->
        <article class="space-y-4 p-6 border-2 border-violent-red rounded-lg">
          <h3 class="font-heading font-bold text-4xl text-violent-red">
            50%+
          </h3>
          <p class="font-body text-lg font-bold text-text-primary">
            CAC Reduction
          </p>
        </article>

        <!-- Achievement 4 -->
        <article class="space-y-4 p-6 border-2 border-violent-red rounded-lg">
          <h3 class="font-heading font-bold text-4xl text-violent-red">
            $5M+
          </h3>
          <p class="font-body text-lg font-bold text-text-primary">
            Revenue Generated
          </p>
        </article>
      </div>
    </div>
  </section>

  <!-- Testimonials Section -->
  <section class="container mx-auto px-6 py-24">
    <div class="max-w-4xl mx-auto">
      <h2 class="font-heading font-bold text-4xl md:text-5xl mb-16 text-center text-text-primary">
        What Clients Say
      </h2>
      <div class="grid md:grid-cols-2 gap-12">
        <!-- Testimonial 1 -->
        <article class="border-2 border-black rounded-lg p-8 space-y-4">
          <div class="flex gap-1 text-violent-red text-xl">
            <span>★</span>
            <span>★</span>
            <span>★</span>
            <span>★</span>
            <span>★</span>
          </div>
          <p class="font-body text-lg italic text-text-secondary leading-relaxed">
            &ldquo;Avalumun transformed our SEO strategy. We went from 0 to 2,000 organic visitors per month in 6 months. His expertise is unmatched.&rdquo;
          </p>
          <div class="pt-4 border-t-2 border-gray-200">
            <p class="font-heading font-bold text-lg text-text-primary">Sarah Chen</p>
            <p class="font-body text-text-secondary">CMO, TechSaaS Inc.</p>
          </div>
        </article>

        <!-- Testimonial 2 -->
        <article class="border-2 border-black rounded-lg p-8 space-y-4">
          <div class="flex gap-1 text-violent-red text-xl">
            <span>★</span>
            <span>★</span>
            <span>★</span>
            <span>★</span>
            <span>★</span>
          </div>
          <p class="font-body text-lg italic text-text-secondary leading-relaxed">
            &ldquo;The GEO and LLM strategies implemented by Avalumun put us 6 months ahead of our competitors. We're dominating our category.&rdquo;
          </p>
          <div class="pt-4 border-t-2 border-gray-200">
            <p class="font-heading font-bold text-lg text-text-primary">Marcus Johnson</p>
            <p class="font-body text-text-secondary">Founder, AI Tools Co.</p>
          </div>
        </article>

        <!-- Testimonial 3 -->
        <article class="border-2 border-black rounded-lg p-8 space-y-4">
          <div class="flex gap-1 text-violent-red text-xl">
            <span>★</span>
            <span>★</span>
            <span>★</span>
            <span>★</span>
            <span>★</span>
          </div>
          <p class="font-body text-lg italic text-text-secondary leading-relaxed">
            &ldquo;Our product page traffic increased by 320% and we saw a 155% boost in online sales. Best investment ever.&rdquo;
          </p>
          <div class="pt-4 border-t-2 border-gray-200">
            <p class="font-heading font-bold text-lg text-text-primary">Emily Rodriguez</p>
            <p class="font-body text-text-secondary">E-commerce Director, FashionHub</p>
          </div>
        </article>

        <!-- Testimonial 4 -->
        <article class="border-2 border-black rounded-lg p-8 space-y-4">
          <div class="flex gap-1 text-violent-red text-xl">
            <span>★</span>
            <span>★</span>
            <span>★</span>
            <span>★</span>
            <span>★</span>
          </div>
          <p class="font-body text-lg italic text-text-secondary leading-relaxed">
            &ldquo;The technical SEO audit uncovered issues we didn't even know existed. Avalumun's systematic approach is incredible.&rdquo;
          </p>
          <div class="pt-4 border-t-2 border-gray-200">
            <p class="font-heading font-bold text-lg text-text-primary">David Kim</p>
            <p class="font-body text-text-secondary">Head of Product, Fintech Solutions</p>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- Newsletter CTA Section -->
  <section class="container mx-auto px-6 py-24">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="font-heading font-bold text-4xl md:text-5xl mb-6 text-text-primary">
        Get Exclusive SEO Strategies
      </h2>
      <p class="font-body text-xl text-text-secondary mb-12 leading-relaxed">
        Subscribe to receive weekly SEO strategies, case studies, and industry insights directly to your inbox. No spam, just actionable advice.
      </p>
      <NewsletterForm />
    </div>
  </section>
</Layout>
