---
// Footer Component
// Minimal footer with copyright and optional social links
---

<footer class="border-t-2 border-black bg-white">
  <div class="container mx-auto px-6 py-12">
    <div class="flex flex-col md:flex-row justify-between items-center space-y-4 md:space-y-0">
      <!-- Copyright -->
      <p class="font-body text-text-secondary text-sm">
        © {new Date().getFullYear()} Avalumun Sekulla Nyior. All rights reserved.
      </p>

      <!-- Social Links (Optional - add your social media links here) -->
      <div class="flex space-x-6">
        <!-- Placeholder for social links -->
        <!-- Uncomment and add your social media links:
        <a href="#" class="text-text-secondary hover:text-violent-red transition-colors" aria-label="LinkedIn">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">...</svg>
        </a>
        -->
      </div>
    </div>
  </div>
</footer>
