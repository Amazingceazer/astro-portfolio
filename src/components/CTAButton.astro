---
// CTA Button Component
// Reusable red accent button with pulse animation
interface Props {
  text: string;
  href?: string;
  type?: 'button' | 'submit';
  class?: string; // Optional extra classes
  ariaLabel?: string;
}

const { text, href, type = 'button', class: className = '', ariaLabel } = Astro.props;

const baseClass =
  'inline-flex items-center justify-center bg-violent-red text-white font-heading font-bold text-lg px-8 py-4 rounded-lg ' +
  'transition-all duration-300 hover:bg-violent-red-dark hover:scale-105 focus:outline-none focus:ring-2 focus:ring-violent-red focus:ring-offset-2 ' +
  'animate-pulse-red';
---

{href ? (
  <a
    href={href}
    class={`${baseClass} ${className}`}
    aria-label={ariaLabel ?? text}
  >
    {text}
  </a>
) : (
  <button
    type={type}
    class={`${baseClass} ${className} cursor-pointer`}
    aria-label={ariaLabel ?? text}
  >
    {text}
  </button>
)}
